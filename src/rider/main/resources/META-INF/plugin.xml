<idea-plugin require-restart="true">
  <id>com.jetbrains.rider.plugins.llmask</id>
  <name>LLMask</name>
  <version>_PLACEHOLDER_</version>
  <vendor url="https://project-url">Author</vendor>
  <idea-version since-build="_PLACEHOLDER_" until-build="_PLACEHOLDER_" />
  <depends>com.intellij.modules.rider</depends>

  <description>
<![CDATA[
<p>Sample description</p>
]]>
  </description>

  <extensions defaultExtensionNs="com.intellij">
    <applicationConfigurable
        instance="com.jetbrains.rider.plugins.llmask.LLMaskOptionsPage"
        id="LLMask"
        displayName="LLMask"
        parentId="tools"/>
  </extensions>

  <actions>
    <action id="LLMask.HelloWorld"
            class="com.jetbrains.rider.plugins.llmask.HelloWorldAction"
            text="Hello World (LLMask)">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
  </actions>

</idea-plugin>
